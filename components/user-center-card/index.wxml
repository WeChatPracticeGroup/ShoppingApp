<!--pages/userCenter/components/user-center-card/index.wxml-->
<view class="user-center-card">
  <videw class="user-container">
    <!--未登录-->
    <block wx:if="{{!isLogin}}">
      <view class="user-avatar" bindtap="getUserProfile">
        <image class=" user-avatar-image" src="{{defaultAvatarUrl}}">
        </image>
        <view class="user-avatar-info">
          <text>尚未登录</text>
        </view>
      </view>
    </block>
    <!--用户登录-->
    <block wx:if="{{canIUseOpenData && isLogin}}">
      <view class="user-avatar">
        <view class="user-avatar-image">
          <open-data type="userAvatarUrl"></open-data>
        </view>
        <view class="user-avatar-info ">
          <open-data type="userNickName"></open-data>
        </view>
      </view>
      <view class="user-info">
        <block wx:if="{{!phoneNumber}}">
          <button class="user-info-container user-info-button" bindtap="getPhoneNumber">
            <icon class="iconfont icon-mobile-phone user-info-icon"></icon>
            <view class="user-info-text">
              <text>电话</text>
            </view>
          </button>
        </block>
        <block wx:else>
          <view class="user-info-container">
            <icon class="iconfont icon-mobile-phone user-info-icon"></icon>
            <view class="user-info-text">
              <text>电话</text>
              <text>{{phoneNumber}}</text>
            </view>
          </view>
        </block>
        <view class="user-info-container">
          <icon class="iconfont icon-bookmark user-info-icon"></icon>
          <view class="user-info-text">
            <text>客户类型</text>
            <text>{{userInfo.clientType || defaultClientType}}</text>
          </view>
        </view>
      </view>
    </block>
  </videw>
</view>